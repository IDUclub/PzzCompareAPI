# Template for local dev (.env.development) and production environments.
# Copy to .env.development and fill real values. Do NOT commit the filled file.

# ── Database & broker ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pzz_pipeline
REDIS_URL=redis://localhost:6379/0

# ── LLM backend ──────────────────────────────────────────────────────────────
LLM_BACKEND=vllm
OLLAMA_BASE_URL=http://your-llm-host:11434
VLLM_BASE_URL=http://your-vllm-host:8000
VLLM_API_KEY=
EMBED_MODEL=intfloat/e5-mistral-7b-instruct
GENERATE_MODEL=openai/gpt-oss-20b
VECTORIZER_URL=http://your-vectorizer-host:8002/v1/embeddings

# ── ChatStorage integration (IDUclub ChatStorage service) ────────────────────
# Stores assistant chat history. Leave empty to disable persistence (the
# conversational /chat/stream flow still streams the answer, just doesn't save).
CHAT_STORAGE_BASE_URL=http://10.32.1.99:8010
CHAT_STORAGE_TIMEOUT_SECONDS=10
# Conversational answer over classification results (Ollama /api/chat), streamed
# back to the user. Reuses OLLAMA_BASE_URL (above); the model is chosen per
# request. CHAT_MODEL is the default model when the request omits one (falls
# back to GENERATE_MODEL).
CHAT_MODEL=
CHAT_TEMPERATURE=0.3
CHAT_REQUEST_TIMEOUT_SECONDS=900
CHAT_SYSTEM_PROMPT_PATH=data/chat_system_prompt.txt
# Result GeoJSON is offered as a durable link (/files/result/{id} → 302 to a
# fresh presigned MinIO URL). PUBLIC_BASE_URL makes the stored link absolute
# (e.g. https://api.example.org); leave empty to store a relative path.
PUBLIC_BASE_URL=
GEO_LAYER_URL_TTL_SECONDS=3600

# ── urban_api integration ────────────────────────────────────────────────────
# IDU urban_api base URL. Leave empty to disable /scenarios/* endpoints.
URBAN_API_BASE_URL=
URBAN_API_TIMEOUT_SECONDS=30

# ── Bearer-token verification (Keycloak JWT via JWKS) ────────────────────────
# AUTH_VERIFY=false accepts tokens without signature checks (dev, or when an
# upstream gateway already validated them). Set true + AUTH_SERVER_URL in prod.
# AUTH_SERVER_URL = https://<host>/realms/<realm>
AUTH_VERIFY=false
AUTH_SERVER_URL=
AUTH_CLIENT_ID=
AUTH_VERIFY_AUD=true
# AUTH_VALID_AUDIENCES = comma-separated list
AUTH_VALID_AUDIENCES=
AUTH_JWKS_CACHE_TTL=600
AUTH_USER_CACHE_TTL=300
AUTH_USER_CACHE_SIZE=10000
AUTH_TIMEOUT_SECONDS=5

# ── Object storage (MinIO / S3-compatible) ───────────────────────────────────
# Leave ACCESS_KEY and SECRET_KEY empty to fall back to local filesystem.
FILESERVER_ENDPOINT=
FILESERVER_ACCESS_KEY=
FILESERVER_SECRET_KEY=
FILESERVER_BUCKET_NAME=
FILESERVER_SECURE=false

# ── Pipeline tuning ──────────────────────────────────────────────────────────
TOP_K=10
EMBED_BATCH_SIZE=64
CADASTRAL_VRI_COL=Вид разреш
TOP_N_EMBED_CANDIDATES=5
TOP_N_EMBED_CANDIDATES_HARD=8
MIN_EMBED_CANDIDATE_SIMILARITY=0.52
PRIORITY_MAX_SUM_DEFAULT=20
